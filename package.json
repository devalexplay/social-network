{
  "name": "freedomai-backend",
  "version": "3.0.0",
  "description": "FreedomAI - Advanced Cognitive Engine with Multi-Model AI Assistant",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "production": "NODE_ENV=production node server.js",
    "test": "jest",
    "pm2:start": "pm2 start server.js --name freedomai",
    "pm2:stop": "pm2 stop freedomai",
    "pm2:restart": "pm2 restart freedomai",
    "pm2:logs": "pm2 logs freedomai"
  },
  "keywords": [
    "ai",
    "chatbot",
    "deepseek",
    "claude",
    "gemini",
    "chatgpt",
    "artificial-intelligence",
    "cognitive-engine",
    "freedomai",
    "llm",
    "language-model"
  ],
  "author": "FreedomAI Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/freedomai/freedomai-backend"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ]
  }
}
